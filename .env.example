# =====================================================================
# Frontend env (Vite — all variables must be prefixed with VITE_)
# Copy this file to `.env` and fill in the values from your Firebase
# project console (https://console.firebase.google.com/).
# =====================================================================

# Where the backend API lives. In dev, leave blank to use Vite's
# /api proxy. In production, set to your backend's public URL.
VITE_API_URL=

# Firebase Web App config (Project Settings → Your apps → Config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# =====================================================================
# Backend env (Express API)
# Copy this file to `backend/.env` and fill in real values.
# =====================================================================

PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# CORS allowlist — comma-separated list of origins that may call this API.
# Use "*" only in trusted internal contexts.
ALLOWED_ORIGINS=http://localhost:5173

# Firebase Admin (server-side). Provide EITHER the inline JSON string
# OR a path to a JSON file containing the service account.
FIREBASE_SERVICE_ACCOUNT=
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Supabase (server uses SERVICE_ROLE key to bypass RLS).
# Get these from Project Settings → API in your Supabase dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# OpenRouter — primary LLM provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct
OPENROUTER_REFERER=http://localhost:5173

# System prompt sent to the model on every chat turn
SYSTEM_PROMPT=You are a compassionate mental-health companion. Listen carefully, respond briefly (1-2 sentences), and on the last line of your reply return ONLY a JSON object of the form {"mood_score": <0-10 integer>, "reply": "<your reply>"}. The reply field must contain ONLY the conversational text, with no JSON inside it.

# Optional: Cloudflare Worker fallback when OpenRouter is unavailable
# CF_WORKER_URL=

# Optional: VERCEL_ENV (set automatically on Vercel — informational only)
# VERCEL_ENV=production
